#!/bin/sh
set -eu

found=0

while IFS=: read -r username _ uid _ _ home shell; do
    case "$username" in
        root|nobody) continue ;;
    esac

    [ "$uid" -ge 500 ] 2>/dev/null || continue
    [ "${home#/home/}" != "$home" ] || continue
    [ -n "$shell" ] || continue

    found=1
    group="$(id -gn "$username")"

    # Apple Container provisions the account locked. OpenSSH rejects even a
    # correct public key for a locked account. Password login remains disabled
    # by sshd_config, so an empty local password does not enable remote passwords.
    passwd -d "$username" >/dev/null 2>&1 || true

    install -d -m 0755 -o "$username" -g "$group" "$home"
    install -d -m 0700 -o "$username" -g "$group" "$home/.ssh"
done < /etc/passwd

if [ "$found" -eq 0 ]; then
    echo "No Apple Container user found yet; sshd will still start." >&2
fi

exit 0
